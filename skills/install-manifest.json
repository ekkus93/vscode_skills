{
  "schema_version": 1,
  "manifest_name": "vscode_skills_shared_skill_install_manifest",
  "skills_root": "skills",
  "description": "Machine-readable install manifest for the shared skills library used by vscode_skills/OpenClaw deployments.",
  "install_profiles": {
    "ubuntu_debian_full": {
      "apt": [
        "python3",
        "curl",
        "jq",
        "pandoc",
        "tesseract-ocr",
        "nodejs",
        "npm",
        "libreoffice"
      ],
      "pip": [
        "yfinance",
        "openpyxl",
        "xlrd"
      ],
      "npm_global": [
        "yahoo-finance2"
      ],
      "post_install": [
        "ln -sf \"$(npm bin -g)/yahoo-finance\" /usr/local/bin/yf"
      ]
    },
    "macos_homebrew_full": {
      "brew": [
        "python",
        "curl",
        "jq",
        "pandoc",
        "tesseract",
        "node",
        "libreoffice"
      ],
      "pip": [
        "yfinance",
        "openpyxl",
        "xlrd"
      ],
      "npm_global": [
        "yahoo-finance2"
      ],
      "post_install": [
        "ln -sf \"$(npm bin -g)/yahoo-finance\" /usr/local/bin/yf"
      ]
    }
  },
